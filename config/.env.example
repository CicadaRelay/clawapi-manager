# API Cockpit - Multi-Account Configuration Template
# Copy this file to .env and fill in your credentials

# Antigravity API
ANTIGRAVITY_API_KEY=your_antigravity_key_here
ANTIGRAVITY_API_URL=https://api.antigravity.example.com

# Codex API
CODEX_API_KEY=your_codex_key_here
CODEX_API_URL=https://api.codex.example.com

# Copilot API
COPILOT_API_KEY=your_copilot_key_here
COPILOT_API_URL=https://api.copilot.example.com

# Windsurf API
WINDSURF_API_KEY=your_windsurf_key_here
WINDSURF_API_URL=https://api.windsurf.example.com

# Telegram Alert Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Quota Thresholds (percentage)
QUOTA_WARNING_THRESHOLD=80
QUOTA_CRITICAL_THRESHOLD=95

# Auto-rotation settings
AUTO_ROTATION_ENABLED=true
ROTATION_CHECK_INTERVAL=300  # seconds

# Cost Budget Threshold (USD)
COST_BUDGET_THRESHOLD=100  # Monthly budget limit
